# Mac 서명 + 낫터라이즈용 (복사 후 .env.signing 으로 저장하고 값 채우기 — 커밋 금지)
# 빌드 전:  set -a && source .env.signing && set +a && npm run electron:build:mac

APPLE_ID=your.apple.id@company.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=XXXXXXXXXX

# revoked 인증서가 여러 개 잡힐 때 — find-identity 에서 유효한 줄 그대로:
# export CSC_NAME="Developer ID Application: 회사이름 (XXXXXXXXXX)"
